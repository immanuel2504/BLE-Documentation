{
  "title": "get_bleConfig Response",
  "description": "Returns the current BLE scanner configuration.",
  "type": "object",
  "required": ["command", "command_id", "response", "payload"],
  "properties": {
    "command": {
      "type": "string",
      "const": "get_bleConfig",
      "description": "Echoed command name"
    },
    "command_id": {
      "type": "string",
      "description": "Echoed command ID from the request"
    },
    "response": {
      "type": "string",
      "enum": ["success", "failure"],
      "description": "Command result status"
    },
    "payload": {
      "type": "object",
      "description": "BLE configuration payload on success, or error details on failure.",
      "properties": {
        "ble": {
          "type": "object",
          "description": "The current BLE scanner configuration stored on the reader.",
          "properties": {
            "enable": { "type": "boolean", "description": "Whether BLE scanning is currently enabled." },
            "scanIntervalSec": { "type": "integer", "description": "How frequently the reader collects BLE scan results, in seconds." },
            "additionalFilters": {
              "type": "object",
              "description": "Cross-protocol filters applied to all BLE advertisements.",
              "properties": {
                "rssi": { "type": "integer", "description": "Minimum RSSI threshold in dBm. Advertisements below this value are dropped. Range: -127 to 0." },
                "serviceUuids16": {
                  "type": "array",
                  "description": "List of 16-bit service UUIDs being filtered on.",
                  "items": { "type": "string", "description": "A 16-bit service UUID (hex string)." }
                },
                "serviceUuids128": {
                  "type": "array",
                  "description": "List of 128-bit service UUIDs being filtered on.",
                  "items": { "type": "string", "description": "A 128-bit service UUID string." }
                }
              }
            },
            "protocols": {
              "type": "object",
              "description": "Protocol-specific BLE scanner configurations.",
              "properties": {
                "iBeacon": {
                  "type": "object",
                  "description": "iBeacon scanner configuration.",
                  "properties": {
                    "enabled": { "type": "boolean", "description": "Whether iBeacon filtering is enabled." },
                    "filters": {
                      "type": "array",
                      "description": "Configured iBeacon filters. A beacon is forwarded if it matches any one filter entry.",
                      "items": {
                        "type": "object",
                        "description": "A single iBeacon filter entry.",
                        "properties": {
                          "uuid": { "type": "string", "description": "Proximity UUID." },
                          "major": { "type": "integer", "description": "Major value." },
                          "minor": { "type": "integer", "description": "Minor value." },
                          "txPower": { "type": "integer", "description": "Calibrated RSSI at 1 metre." }
                        }
                      }
                    }
                  }
                },
                "altBeacon": {
                  "type": "object",
                  "description": "AltBeacon scanner configuration.",
                  "properties": {
                    "enabled": { "type": "boolean", "description": "Whether AltBeacon filtering is enabled." },
                    "filters": {
                      "type": "array",
                      "description": "Configured AltBeacon filters. A beacon is forwarded if it matches any one filter entry.",
                      "items": {
                        "type": "object",
                        "description": "A single AltBeacon filter entry.",
                        "properties": {
                          "mfgId": { "type": "string", "description": "Manufacturer ID (hex string)." },
                          "beaconId": { "type": "string", "description": "Beacon ID (UUID string)." },
                          "major": { "type": "integer", "description": "Major value." },
                          "minor": { "type": "integer", "description": "Minor value." },
                          "refRssi": { "type": "integer", "description": "Reference RSSI (TX power at 1 metre)." }
                        }
                      }
                    }
                  }
                },
                "eddystone": {
                  "type": "object",
                  "description": "Eddystone scanner configuration.",
                  "properties": {
                    "enabled": { "type": "boolean", "description": "Whether Eddystone filtering is enabled." },
                    "filters": {
                      "type": "array",
                      "description": "Configured Eddystone filters. Each entry targets a specific frame type via frameType.",
                      "items": {
                        "type": "object",
                        "description": "A single Eddystone filter entry.",
                        "properties": {
                          "frameType": { "type": "string", "enum": ["URL", "UID", "EID", "TLM"], "description": "Eddystone frame type." },
                          "txPower": { "type": "integer", "description": "TX power at 0 m (calibrated RSSI)." },
                          "url": { "type": "string", "description": "Advertised URL (Eddystone-URL frames only)." },
                          "namespace": { "type": "string", "description": "10-byte namespace hex string (Eddystone-UID frames only)." },
                          "instance": { "type": "string", "description": "6-byte instance ID hex string (Eddystone-UID frames only)." },
                          "ephemeralId": { "type": "string", "description": "8-byte ephemeral ID hex string (Eddystone-EID frames only)." }
                        }
                      }
                    }
                  }
                },
                "generic": {
                  "type": "object",
                  "description": "Configuration for generic BLE devices. Filters match on device-level advertisement fields.",
                  "properties": {
                    "enabled": { "type": "boolean", "description": "Whether generic BLE device filtering is enabled." },
                    "filters": {
                      "type": "array",
                      "description": "Configured generic BLE device filters. A device is forwarded if it matches any one filter entry.",
                      "items": {
                        "type": "object",
                        "description": "A single generic BLE device filter entry.",
                        "properties": {
                          "address": { "type": "string", "description": "Bluetooth device MAC address to match." },
                          "addressType": { "type": "string", "enum": ["public", "random"], "description": "Bluetooth address type to match." },
                          "name": { "type": "string", "description": "Device name to match against the Name field in the BLE advertisement." },
                          "alias": { "type": "string", "description": "Device alias to match against the Alias field in the BLE advertisement." }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "examples": [
    {
      "command": "get_bleConfig",
      "command_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "response": "success",
      "payload": {
        "ble": {
          "enable": true,
          "scanIntervalSec": 5,
          "protocols": {
            "iBeacon": {
              "enabled": true,
              "filters": [
                {
                  "uuid": "FDA50693-A4E2-4FB1-AFCF-C6EB07647825",
                  "major": 10001,
                  "minor": 20002,
                  "txPower": -59
                }
              ]
            }
          },
          "additionalFilters": {
            "rssi": -80,
            "serviceUuids16": ["FEAA", "FE9B"],
            "serviceUuids128": ["FDA50693-A4E2-4FB1-AFCF-C6EB07647825"]
          }
        }
      }
    }
  ]
}
