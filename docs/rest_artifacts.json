                },
                "eddystone": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean"
                    },
                    "filters": {
                      "type": "array",
                      "description": "Filter by Eddystone frame fields.",
                      "items": {
                        "type": "object",
                        "properties": {
                          "frameType": {
                            "type": "string",
                            "enum": [
                              "URL",
                              "UID",
                              "EID",
                              "TLM"
                            ]
                          },
                          "txPower": {
                            "type": "integer"
                          },
                          "url": {
                            "type": "string",
                            "description": "Advertised URL (Eddystone-URL only)."
                          },
                          "namespace": {
                            "type": "string",
                            "description": "10-byte namespace hex string (Eddystone-UID only)."
                          },
                          "instance": {
                            "type": "string",
                            "description": "6-byte instance ID hex string (Eddystone-UID only)."
                          },
                          "ephemeralId": {
                            "type": "string",
                            "description": "8-byte ephemeral ID hex string (Eddystone-EID only)."
                          }
                        }
                      }
                    }
                  }
                },
                "generic": {
                  "type": "object",
                  "description": "Configuration for generic BLE devices.",
                  "properties": {
                    "enabled": {
                      "type": "boolean"
                    },
                    "filters": {
                      "type": "array",
                      "description": "List of filter objects for generic BLE devices.",
                      "items": {
                        "type": "object",
                        "properties": {
                          "address": {
                            "type": "string",
                            "description": "Bluetooth device MAC address."
                          },
                          "addressType": {
                            "type": "string",
                            "enum": [
                              "public",
                              "random"
                            ]
                          },
                          "name": {
                            "type": "string"
                          },
                          "alias": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "examples": [
        {
          "ble": {
