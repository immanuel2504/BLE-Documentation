    "response_schema": {
      "title": "Get BLE Configuration Response",
      "description": "Returns the current BLE scanner configuration stored on the reader.",
      "type": "object",
      "required": [
        "ble"
      ],
      "properties": {
        "ble": {
          "type": "object",
          "properties": {
            "enable": {
              "type": "boolean",
              "example": true
            },
            "scanIntervalSec": {
              "type": "integer",
              "example": 5
            },
            "additionalFilters": {
              "type": "object",
              "properties": {
                "rssi": {
                  "type": "integer",
                  "example": -80
                },
                "serviceUuids16": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "serviceUuids128": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "protocols": {
              "type": "object",
              "description": "Protocol-specific BLE scanner configurations.",
              "properties": {
                "iBeacon": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean"
                    },
                    "filters": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "uuid": {
                            "type": "string",
                            "description": "Proximity UUID."
                          },
                          "major": {
                            "type": "integer"
                          },
                          "minor": {
                            "type": "integer"
                          },
                          "txPower": {
                            "type": "integer",
                            "description": "Calibrated RSSI at 1 metre."
                          }
                        }
                      }
                    }
                  }
                },
                "altBeacon": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean"
                    },
                    "filters": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "mfgId": {
                            "type": "string",
                            "description": "Manufacturer ID (hex string)."
                          },
                          "beaconId": {
                            "type": "string",
                            "description": "Beacon ID (UUID string)."
                          },
                          "major": {
                            "type": "integer"
                          },
                          "minor": {
                            "type": "integer"
                          },
                          "refRssi": {
