{
  "getBleConfig": {
    "request_example": null,
    "request_schema": {
      "title": "Get BLE Configuration Request",
      "description": "No request body required. Use GET /cloud/ble-config.",
      "type": "object",
      "properties": {},
      "additionalProperties": false
    },
    "response_example": {
      "ble": {
        "enable": true,
        "scanIntervalSec": 5,
        "protocols": {
          "iBeacon": {
            "enabled": true,
            "filters": [
              {
                "uuid": "FDA50693-A4E2-4FB1-AFCF-C6EB07647825",
                "major": 10001,
                "minor": 20002,
                "txPower": -59
              }
            ]
          }
        },
        "additionalFilters": {
          "rssi": -80,
          "serviceUuids16": [
            "FEAA",
            "FE9B"
          ],
          "serviceUuids128": [
            "FDA50693-A4E2-4FB1-AFCF-C6EB07647825"
          ]
        }
      }
    },
    "response_schema": {
      "title": "Get BLE Configuration Response",
      "description": "Returns the current BLE scanner configuration stored on the reader.",
      "type": "object",
      "required": [
        "ble"
      ],
      "properties": {
        "ble": {
          "type": "object",
          "description": "The current BLE scanner configuration stored on the reader.",
          "properties": {
            "enable": {
              "type": "boolean",
              "description": "Whether BLE scanning is currently enabled.",
              "example": true
            },
            "scanIntervalSec": {
              "type": "integer",
              "description": "How frequently the reader collects BLE scan results, in seconds.",
              "example": 5
            },
            "additionalFilters": {
              "type": "object",
              "description": "Cross-protocol filters applied to all BLE advertisements.",
              "properties": {
                "rssi": {
                  "type": "integer",
                  "description": "Minimum RSSI threshold in dBm. Advertisements below this value are dropped. Range: -127 to 0.",
                  "example": -80
                },
                "serviceUuids16": {
                  "type": "array",
                  "description": "List of 16-bit service UUIDs being filtered on.",
                  "items": {
                    "type": "string",
                    "description": "A 16-bit service UUID (hex string)."
                  }
                },
                "serviceUuids128": {
                  "type": "array",
                  "description": "List of 128-bit service UUIDs being filtered on.",
                  "items": {
                    "type": "string",
                    "description": "A 128-bit service UUID string."
                  }
                }
              }
            },
            "protocols": {
              "type": "object",
              "description": "Protocol-specific BLE scanner configurations.",
              "properties": {
                "iBeacon": {
                  "type": "object",
                  "description": "iBeacon scanner configuration.",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Whether iBeacon filtering is enabled."
                    },
                    "filters": {
                      "type": "array",
                      "description": "Configured iBeacon filters. A beacon is forwarded if it matches any one filter entry.",
                      "items": {
                        "type": "object",
                        "description": "A single iBeacon filter entry.",
                        "properties": {
                          "uuid": {
                            "type": "string",
                            "description": "Proximity UUID."
                          },
                          "major": {
                            "type": "integer",
                            "description": "Major value."
                          },
                          "minor": {
                            "type": "integer",
                            "description": "Minor value."
                          },
                          "txPower": {
                            "type": "integer",
                            "description": "Calibrated RSSI at 1 metre."
                          }
                        }
                      }
                    }
                  }
                },
                "altBeacon": {
                  "type": "object",
                  "description": "AltBeacon scanner configuration.",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Whether AltBeacon filtering is enabled."
                    },
                    "filters": {
                      "type": "array",
                      "description": "Configured AltBeacon filters. A beacon is forwarded if it matches any one filter entry.",
                      "items": {
                        "type": "object",
                        "description": "A single AltBeacon filter entry.",
                        "properties": {
                          "mfgId": {
                            "type": "string",
                            "description": "Manufacturer ID (hex string)."
                          },
                          "beaconId": {
                            "type": "string",
                            "description": "Beacon ID (UUID string)."
                          },
                          "major": {
                            "type": "integer",
                            "description": "Major value."
                          },
                          "minor": {
                            "type": "integer",
                            "description": "Minor value."
                          },
                          "refRssi": {
                            "type": "integer",
                            "description": "Reference RSSI (TX power at 1 metre)."
                          }
                        }
                      }
                    }
                  }
                },
                "eddystone": {
                  "type": "object",
                  "description": "Eddystone scanner configuration.",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Whether Eddystone filtering is enabled."
                    },
                    "filters": {
                      "type": "array",
                      "description": "Configured Eddystone filters. Each entry targets a specific frame type via frameType.",
                      "items": {
                        "type": "object",
                        "description": "A single Eddystone filter entry.",
                        "properties": {
                          "frameType": {
                            "type": "string",
                            "enum": [
                              "URL",
                              "UID",
                              "EID",
                              "TLM"
                            ],
                            "description": "Eddystone frame type."
                          },
                          "txPower": {
                            "type": "integer",
                            "description": "TX power at 0 m (calibrated RSSI)."
                          },
                          "url": {
                            "type": "string",
                            "description": "Advertised URL (Eddystone-URL frames only)."
                          },
                          "namespace": {
                            "type": "string",
                            "description": "10-byte namespace hex string (Eddystone-UID frames only)."
                          },
                          "instance": {
                            "type": "string",
                            "description": "6-byte instance ID hex string (Eddystone-UID frames only)."
                          },
                          "ephemeralId": {
                            "type": "string",
                            "description": "8-byte ephemeral ID hex string (Eddystone-EID frames only)."
                          }
                        }
                      }
                    }
                  }
                },
                "generic": {
                  "type": "object",
                  "description": "Configuration for generic BLE devices. Filters match on device-level advertisement fields.",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Whether generic BLE device filtering is enabled."
                    },
                    "filters": {
                      "type": "array",
                      "description": "Configured generic BLE device filters. A device is forwarded if it matches any one filter entry.",
                      "items": {
                        "type": "object",
                        "description": "A single generic BLE device filter entry.",
                        "properties": {
                          "address": {
                            "type": "string",
                            "description": "Bluetooth device MAC address to match."
                          },
                          "addressType": {
                            "type": "string",
                            "enum": [
                              "public",
                              "random"
                            ],
                            "description": "Bluetooth address type to match."
                          },
                          "name": {
                            "type": "string",
                            "description": "Device name to match against the Name field in the BLE advertisement."
                          },
                          "alias": {
                            "type": "string",
                            "description": "Device alias to match against the Alias field in the BLE advertisement."
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "examples": [
        {
          "ble": {
            "enable": true,
            "scanIntervalSec": 5,
            "protocols": {
              "iBeacon": {
                "enabled": true,
                "filters": [
                  {
                    "uuid": "FDA50693-A4E2-4FB1-AFCF-C6EB07647825",
                    "major": 10001,
                    "minor": 20002,
                    "txPower": -59
                  }
                ]
              }
            },
            "additionalFilters": {
              "rssi": -80,
              "serviceUuids16": [
                "FEAA",
                "FE9B"
              ],
              "serviceUuids128": [
                "FDA50693-A4E2-4FB1-AFCF-C6EB07647825"
              ]
            }
          }
        }
      ]
    }
  },
  "getStatus": {
    "request_example": null,
    "request_schema": {
      "title": "Get Reader Status Request",
      "description": "No request body required. Use GET /cloud/status.",
      "type": "object",
      "properties": {},
      "additionalProperties": false
    },
    "response_example": {
      "radioActivity": "inactive",
      "radioConnection": "connected",
      "temperature": 33,
      "uptime": "0D1H13M15S",
      "systemTime": "13/06/2024 11:19",
      "cpu": {
        "system": 0,
        "user": 2
      },
      "ram": {
        "free": 76,
        "total": 100,
        "used": 24
      },
      "ble": {
        "scanState": "running",
        "scanStartTime": "2026-05-21T13:46:16.955Z",
        "beaconCounts": {
          "total": 108,
          "iBeacon": 75,
          "altBeacon": 33,
          "eddystone": 0,
          "generic": 0
        }
      }
    },
    "response_schema": {
      "title": "Get Reader Status Response",
      "description": "Returns the reader's operational status and runtime statistics. When BLE is supported and active, the response includes a `ble` section with the scanner state and beacon counts.",
      "type": "object",
      "properties": {
        "ble": {
          "type": "object",
          "description": "BLE scanner runtime status. Present only when BLE is supported and status is available.",
          "properties": {
            "scanState": {
              "type": "string",
              "enum": [
                "running",
                "stopped"
              ],
              "description": "Current BLE scanner state.",
              "example": "running"
            },
            "scanStartTime": {
              "type": "string",
              "format": "date-time",
              "description": "ISO 8601 timestamp when the BLE scan was last started.",
              "example": "2026-05-21T13:46:16.955Z"
            },
            "beaconCounts": {
              "type": "object",
              "description": "BLE advertisement counts by beacon format for the current scan window.",
              "properties": {
                "total": {
                  "type": "integer",
                  "description": "Total BLE advertisements observed.",
                  "example": 108
                },
                "iBeacon": {
                  "type": "integer",
                  "description": "Number of iBeacon advertisements observed.",
                  "example": 75
                },
                "altBeacon": {
                  "type": "integer",
                  "description": "Number of AltBeacon advertisements observed.",
                  "example": 33
                },
                "eddystone": {
                  "type": "integer",
                  "description": "Number of Eddystone advertisements observed.",
                  "example": 0
                },
                "generic": {
                  "type": "integer",
                  "description": "Number of generic BLE advertisements observed.",
                  "example": 0
                }
              }
            }
          }
        },
        "radioActivity": {
          "type": "string",
          "enum": [
            "active",
            "inactive"
          ],
          "description": "Current RFID radio activity state.",
          "example": "inactive"
        },
        "radioConnection": {
          "type": "string",
          "enum": [
            "connected",
            "disconnected"
          ],
          "description": "Current connection state of the RFID radio.",
          "example": "connected"
        },
        "antennas": {
          "type": "object",
          "description": "Antenna connection status keyed by antenna port (connected or disconnected)."
        },
        "cpu": {
          "type": "object",
          "description": "Current CPU utilization percentages.",
          "properties": {
            "system": {
              "type": "number"
            },
            "user": {
              "type": "number"
            }
          }
        },
        "ram": {
          "type": "object",
          "description": "RAM usage statistics.",
          "properties": {
            "free": {
              "type": "number"
            },
            "total": {
              "type": "number"
            },
            "used": {
              "type": "number"
            }
          }
        },
        "temperature": {
          "type": "number",
          "description": "Current reader internal temperature in degrees Celsius.",
          "example": 33
        },
        "uptime": {
          "type": "string",
          "description": "Elapsed time since the reader last started.",
          "example": "0D1H13M15S"
        },
        "systemTime": {
          "type": "string",
          "description": "Current reader system time.",
          "example": "13/06/2024 11:19"
        }
      },
      "examples": [
        {
          "radioActivity": "inactive",
          "radioConnection": "connected",
          "temperature": 33,
          "uptime": "0D1H13M15S",
          "systemTime": "13/06/2024 11:19",
          "cpu": {
            "system": 0,
            "user": 2
          },
          "ram": {
            "free": 76,
            "total": 100,
            "used": 24
          },
          "ble": {
            "scanState": "running",
            "scanStartTime": "2026-05-21T13:46:16.955Z",
            "beaconCounts": {
              "total": 108,
              "iBeacon": 75,
              "altBeacon": 33,
              "eddystone": 0,
              "generic": 0
            }
          }
        }
      ]
    }
  },
  "setBleConfig": {
    "request_example": {
      "ble": {
        "enable": true,
        "scanIntervalSec": 5,
        "protocols": {
          "iBeacon": {
            "enabled": true,
            "filters": [
              {
                "uuid": "FDA50693-A4E2-4FB1-AFCF-C6EB07647825",
                "major": 10001,
                "minor": 20002,
                "txPower": -59
              }
            ]
          },
          "eddystone": {
            "enabled": true,
            "filters": [
              {
                "frameType": "URL",
                "txPower": -59,
                "url": "https://www.zebra.com"
              }
            ]
          }
        },
        "additionalFilters": {
          "rssi": -70
        }
      }
    },
    "request_schema": {
      "title": "Set BLE Configuration Request",
      "description": "Configure the BLE scanner. The ble.enable field is required in every request.",
      "type": "object",
      "required": [
        "ble"
      ],
      "properties": {
        "ble": {
          "type": "object",
          "required": [
            "enable"
          ],
          "properties": {
            "enable": {
              "type": "boolean",
              "description": "Enable or disable BLE scanning. Required in every request.",
              "example": true
            },
            "scanIntervalSec": {
              "type": "integer",
              "minimum": 1,
              "description": "How frequently the reader collects BLE scan results, in seconds. Minimum value is 1.",
              "example": 5
            },
            "additionalFilters": {
              "type": "object",
              "description": "Cross-protocol filters applied to all BLE advertisements.",
              "properties": {
                "rssi": {
                  "type": "integer",
                  "minimum": -127,
                  "maximum": 0,
                  "description": "Minimum RSSI threshold in dBm. Advertisements below this value are dropped. Range: -127 to 0.",
                  "example": -70
                },
                "serviceUuids16": {
                  "type": "array",
                  "description": "List of 16-bit service UUIDs to filter on.",
                  "items": {
                    "type": "string"
                  },
                  "example": [
                    "FEAA",
                    "FE9B"
                  ]
                },
                "serviceUuids128": {
                  "type": "array",
                  "description": "List of 128-bit service UUIDs to filter on.",
                  "items": {
                    "type": "string"
                  },
                  "example": [
                    "FDA50693-A4E2-4FB1-AFCF-C6EB07647825"
                  ]
                }
              }
            },
            "protocols": {
              "type": "object",
              "description": "Protocol-specific BLE scanner configurations.",
              "properties": {
                "iBeacon": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "example": true
                    },
                    "filters": {
                      "type": "array",
                      "description": "Filter by iBeacon fields. A beacon is forwarded if it matches any one filter entry.",
                      "items": {
                        "type": "object",
                        "properties": {
                          "uuid": {
                            "type": "string",
                            "description": "Proximity UUID.",
                            "example": "FDA50693-A4E2-4FB1-AFCF-C6EB07647825"
                          },
                          "major": {
                            "type": "integer",
                            "description": "Major value.",
                            "example": 10001
                          },
                          "minor": {
                            "type": "integer",
                            "description": "Minor value.",
                            "example": 20002
                          },
                          "txPower": {
                            "type": "integer",
                            "description": "Calibrated RSSI at 1 metre.",
                            "example": -59
                          }
                        }
                      }
                    }
                  }
                },
                "altBeacon": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "example": true
                    },
                    "filters": {
                      "type": "array",
                      "description": "Filter by AltBeacon fields. A beacon is forwarded if it matches any one filter entry.",
                      "items": {
                        "type": "object",
                        "properties": {
                          "mfgId": {
                            "type": "string",
                            "description": "Manufacturer ID (hex string).",
                            "example": "0118"
                          },
                          "beaconId": {
                            "type": "string",
                            "description": "Beacon ID (UUID string).",
                            "example": "2F234454-CF6D-4A0F-ADF2-F4911BA9FFA7"
                          },
                          "major": {
                            "type": "integer",
                            "description": "Major value.",
                            "example": 4
                          },
                          "minor": {
                            "type": "integer",
                            "description": "Minor value.",
                            "example": 4
                          },
                          "refRssi": {
                            "type": "integer",
                            "description": "Reference RSSI (TX power at 1 metre).",
                            "example": -100
                          }
                        }
                      }
                    }
                  }
                },
                "eddystone": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "example": true
                    },
                    "filters": {
                      "type": "array",
                      "description": "Filter by Eddystone frame fields. Use frameType to target a specific frame type (URL, UID, EID). All other fields are optional and frame-type-specific.",
                      "items": {
                        "type": "object",
                        "properties": {
                          "frameType": {
                            "type": "string",
                            "enum": [
                              "URL",
                              "UID",
                              "EID",
                              "TLM"
                            ],
                            "description": "Eddystone frame type.",
                            "example": "URL"
                          },
                          "txPower": {
                            "type": "integer",
                            "description": "TX power at 0 m (calibrated RSSI).",
                            "example": -59
                          },
                          "url": {
                            "type": "string",
                            "description": "Advertised URL (Eddystone-URL frames only).",
                            "example": "https://www.zebra.com"
                          },
                          "namespace": {
                            "type": "string",
                            "description": "10-byte namespace hex string (Eddystone-UID frames only).",
                            "example": "0102030405060708090A"
                          },
                          "instance": {
                            "type": "string",
                            "description": "6-byte instance ID hex string (Eddystone-UID frames only).",
                            "example": "000000000001"
                          },
                          "ephemeralId": {
                            "type": "string",
                            "description": "8-byte ephemeral ID hex string (Eddystone-EID frames only).",
                            "example": "0102030405060708"
                          }
                        }
                      }
                    }
                  }
                },
                "generic": {
                  "type": "object",
                  "description": "Configuration for generic BLE devices. Filters match on device-level advertisement fields.",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "example": true
                    },
                    "filters": {
                      "type": "array",
                      "description": "List of filter objects for generic BLE devices. A device is forwarded if it matches any one filter entry.",
                      "items": {
                        "type": "object",
                        "properties": {
                          "address": {
                            "type": "string",
                            "description": "Bluetooth device MAC address to match.",
                            "example": "7E:41:25:1E:D5:16"
                          },
                          "addressType": {
                            "type": "string",
                            "enum": [
                              "public",
                              "random"
                            ],
                            "description": "Bluetooth address type to match.",
                            "example": "random"
                          },
                          "name": {
                            "type": "string",
                            "description": "Device name to match against the Name field in the BLE advertisement.",
                            "example": "BLEPeripheralApp"
                          },
                          "alias": {
                            "type": "string",
                            "description": "Device alias to match against the Alias field in the BLE advertisement.",
                            "example": "BLEPeripheralApp"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false,
      "examples": [
        {
          "ble": {
            "enable": true
          }
        },
        {
          "ble": {
            "enable": true,
            "scanIntervalSec": 5
          }
        },
        {
          "ble": {
            "enable": true,
            "scanIntervalSec": 10,
            "additionalFilters": {
              "rssi": -70
            }
          }
        },
        {
          "ble": {
            "enable": true,
            "scanIntervalSec": 5,
            "protocols": {
              "iBeacon": {
                "enabled": true,
                "filters": [
                  {
                    "uuid": "FDA50693-A4E2-4FB1-AFCF-C6EB07647825",
                    "major": 10001,
                    "minor": 20002,
                    "txPower": -59
                  }
                ]
              },
              "altBeacon": {
                "enabled": true,
                "filters": [
                  {
                    "mfgId": "0118",
                    "beaconId": "2F234454-CF6D-4A0F-ADF2-F4911BA9FFA7",
                    "major": 4,
                    "minor": 4,
                    "refRssi": -100
                  }
                ]
              },
              "eddystone": {
                "enabled": true,
                "filters": [
                  {
                    "frameType": "URL",
                    "txPower": -59,
                    "url": "https://www.zebra.com"
                  },
                  {
                    "frameType": "UID",
                    "txPower": -18,
                    "namespace": "0102030405060708090A",
                    "instance": "000000000001"
                  },
                  {
                    "frameType": "EID",
                    "txPower": -18,
                    "ephemeralId": "0102030405060708"
                  }
                ]
              },
              "generic": {
                "enabled": true,
                "filters": [
                  {
                    "address": "7E:41:25:1E:D5:16",
                    "addressType": "random",
                    "name": "BLEPeripheralApp",
                    "alias": "BLEPeripheralApp"
                  }
                ]
              }
            },
            "additionalFilters": {
              "rssi": -80,
              "serviceUuids16": [
                "FEAA",
                "FE9B"
              ],
              "serviceUuids128": [
                "FDA50693-A4E2-4FB1-AFCF-C6EB07647825"
              ]
            }
          }
        },
        {
          "ble": {
            "enable": false
          }
        }
      ]
    },
    "response_example": {},
    "response_schema": {
      "title": "Set BLE Configuration Response",
      "description": "Empty object returned on successful BLE configuration update.",
      "type": "object",
      "properties": {},
      "additionalProperties": false,
      "examples": [
        {}
      ]
    }
  },
  "start": {
    "request_example": {
      "scanType": [
        "ble"
      ]
    },
    "request_schema": {
      "title": "Start BLE Scan Request",
      "description": "Request payload for starting BLE scanning. Use scanType to control which scan modes are activated.",
      "type": "object",
      "properties": {
        "scanType": {
          "type": "array",
          "description": "Scan modes to activate. Use [\"ble\"] for BLE only, or [\"ble\", \"rfid\"] for combined BLE and RFID scanning.",
          "items": {
            "type": "string",
            "enum": [
              "ble",
              "rfid"
            ]
          },
          "example": [
            "ble"
          ]
        }
      },
      "additionalProperties": false,
      "examples": [
        {
          "scanType": [
            "ble"
          ]
        },
        {
          "scanType": [
            "ble",
            "rfid"
          ]
        }
